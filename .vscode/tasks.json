{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start AltClaw",
            "dependsOn": [
                "Altclaw Backend",
                "Altclaw Frontend"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Altclaw Backend",
            "type": "shell",
            "command": "go run . -c ../../.altclaw -a :9090 -v ../../.workspace",
            "options": {
                "cwd": "${workspaceFolder}/cmd/altclaw",
                "env": {
                    "TASKR_WATCH_PATHS": "../../"
                }
            },
            "presentation": {
                "panel": "dedicated",
                "group": "dev"
            },
            "problemMatcher": []
        },
        {
            "label": "Altclaw Frontend",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/vue"
            },
            "presentation": {
                "panel": "dedicated",
                "group": "dev"
            },
            "problemMatcher": []
        },
        {
            "label": "Altclaw Run Script",
            "type": "shell",
            "command": "go run . run -c ../../.altclaw run.js ../../workspace",
            "options": {
                "cwd": "${workspaceFolder}/cmd/altclaw"
            },
            "presentation": {
                "panel": "dedicated",
                "group": "dev"
            },
            "problemMatcher": []
        },
        {
            "label": "Altclaw Cli",
            "type": "shell",
            "command": "go run . -c ../../.altclaw --tui ../../workspace",
            "options": {
                "cwd": "${workspaceFolder}/cmd/altclaw"
            },
            "presentation": {
                "panel": "dedicated",
                "group": "dev"
            },
            "problemMatcher": []
        },
    ]
}